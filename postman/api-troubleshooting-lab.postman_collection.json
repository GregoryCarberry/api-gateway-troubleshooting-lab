{
  "info": {
    "_postman_id": "8a6ed3aa-c3fa-4d9b-bf93-4a74ecf4b211",
    "name": "API Troubleshooting Lab - End-to-End Demo",
    "description": "Postman collection for exercising the API Troubleshooting Lab through the gateway. Covers health checks, authentication failures, XML validation errors, backend failure simulation, request tracing, and rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "api_key",
      "value": "lab-demo-key"
    },
    {
      "key": "request_id",
      "value": ""
    },
    {
      "key": "order_id",
      "value": ""
    },
    {
      "key": "valid_order_xml",
      "value": "<Order>\n  <CustomerID>12345</CustomerID>\n  <ProductID>ABC123</ProductID>\n  <Quantity>2</Quantity>\n</Order>"
    },
    {
      "key": "malformed_order_xml",
      "value": "<Order>\n  <CustomerID>12345</CustomerID>\n  <ProductID>ABC123</ProductID>\n  <Quantity>2</Quantity>"
    },
    {
      "key": "missing_fields_xml",
      "value": "<Order>\n  <CustomerID>12345</CustomerID>\n  <Quantity>2</Quantity>\n</Order>"
    },
    {
      "key": "invalid_quantity_xml",
      "value": "<Order>\n  <CustomerID>12345</CustomerID>\n  <ProductID>ABC123</ProductID>\n  <Quantity>0</Quantity>\n</Order>"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('request_id', pm.variables.replaceIn('{{$guid}}'));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Request-ID",
                "value": "{{request_id}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Basic health check for the FastAPI gateway."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response contains gateway status', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('api-gateway');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Backend Health via Gateway",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{request_id}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/gateway/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "gateway",
                "health"
              ]
            },
            "description": "Verifies gateway-to-backend connectivity and request tracing through the proxy."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Request ID returned', function () {",
                  "  pm.expect(pm.response.json().request_id).to.exist;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders - Success and Validation",
      "item": [
        {
          "name": "Create Order - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{request_id}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/xml",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Happy path request through the gateway using a valid XML payload.",
            "body": {
              "mode": "raw",
              "raw": "{{valid_order_xml}}",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response contains OrderID', function () {",
                  "  const text = pm.response.text();",
                  "  pm.expect(text).to.include('<OrderCreated>');",
                  "  const match = text.match(/<OrderID>([^<]+)<\\/OrderID>/);",
                  "  pm.expect(match).to.not.be.null;",
                  "  pm.collectionVariables.set('order_id', match[1]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Order - Wrong Content-Type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{request_id}}",
