            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 415', function () { pm.response.to.have.status(415); });",
                  "pm.test('Unsupported media type error returned', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.error).to.eql('Unsupported Media Type');",
                  "});"
                ]
              }
            }
          ]
        },
