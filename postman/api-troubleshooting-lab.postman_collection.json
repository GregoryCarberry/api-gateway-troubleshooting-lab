              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Returns either 201 or 429 depending on current rate window', function () {",
                  "  pm.expect([201, 429]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
